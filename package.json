    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-unicorn": "^72.0.0",
    "globals": "^17.0.0",
    "prettier": "^3.4.2",
