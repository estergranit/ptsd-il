    "seed": "nest build && node --env-file .env dist/seed.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test:e2e": "node --test --test-reporter=spec \"test/**/*.e2e-spec.ts\"",
    "test:e2e:watch": "node --test --watch \"test/**/*.e2e-spec.ts\""
  },
  "dependencies": {
